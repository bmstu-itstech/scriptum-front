{
  "name": "scriptum-front",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:eslint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:eslint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "lint:stylelint": "stylelint '**/*.{css,scss}'",
    "lint:stylelint:fix": "stylelint '**/*.{css,scss}' --fix",
    "format:fix": "prettier --write src",
    "lint:all": "npm run lint:eslint:fix && npm run lint:stylelint:fix && npm run format:fix",
    "ts:check": "tsc --noEmit",
    "api:generate": "npx swagger-typescript-api generate --path https://raw.githubusercontent.com/bmstu-itstech/scriptum-back/refs/heads/main/api/v2/scriptum.swagger.yaml --output ./src/shared/api/generated --modular --axios"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "classnames": "^2.5.1",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "formik": "^2.4.9",
    "jose": "^6.2.3",
    "lodash.debounce": "^4.0.8",
    "next": "15.5.16",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-select": "^5.10.2",
    "react-toastify": "^11.1.0",
    "use-debounce": "^10.1.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.16",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5"
  }
}
